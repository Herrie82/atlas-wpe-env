# WPE WebKit 2.52.4 - Atlas fullscreen CRASH fixes (2026-07-07, cleaned - no debug instrumentation)
# Apply from the wpewebkit-2.52.4 source root: patch -p1 < this-file
# 3 fixes so HTML5 fullscreen ENTERS without crashing (does NOT fill the screen - that needs the
# media-player handoff; the surface-resize approach stalls WebKit's fullscreen render loop):
#  1. AcceleratedSurface.cpp nextTarget(): empty-vector guard (root WebProcess SIGBUS / UAF)
#  2. AcceleratedSurface.cpp initializeTarget(): m_hostFD.duplicate() not WTF::move (garbage-backend variant)
#  3. WebFullScreenManagerProxy.{h,cpp}: m_client CheckedPtr -> WeakPtr (UIProcess dangling-CheckedPtr abort)
#
--- a/Source/WebKit/WebProcess/WebPage/CoordinatedGraphics/AcceleratedSurface.cpp	2026-05-11 14:54:39.647206300 +0200
+++ b/Source/WebKit/WebProcess/WebPage/CoordinatedGraphics/AcceleratedSurface.cpp	2026-07-07 07:27:45.341831832 +0200
@@ -814,8 +814,14 @@
 AcceleratedSurface::RenderTarget* AcceleratedSurface::SwapChain::nextTarget()
 {
 #if USE(WPE_RENDERER)
-    if (m_type == Type::WPEBackend)
+    if (m_type == Type::WPEBackend) {
+        // ATLAS FIX: m_lockedTargets[0] on an EMPTY vector is UB -> garbage RenderTarget* -> UAF SIGBUS in
+        // willRenderFrame (wpe_renderer_backend_egl_target_frame_will_render) when the compositor renders a
+        // frame after SwapChain::reset() cleared the targets (fullscreen teardown) before a new one installs.
+        if (m_lockedTargets.isEmpty())
+            return nullptr;
         return m_lockedTargets[0].get();
+    }
 #endif
 
 #if (PLATFORM(GTK) || ENABLE(WPE_PLATFORM)) && (USE(GBM) || OS(ANDROID))
@@ -912,7 +918,9 @@
 uint64_t AcceleratedSurface::SwapChain::initializeTarget(const AcceleratedSurface& surface)
 {
     ASSERT(m_type == Type::WPEBackend);
-    auto target = RenderTargetWPEBackend::create(m_surfaceID, m_initialSize, WTF::move(m_hostFD), surface);
+    // ATLAS FIX: duplicate the host fd instead of WTF::move()ing it away, so a 2nd initializeTarget on the
+    // same SwapChain (fullscreen teardown+recreate) doesn't pass a moved-from fd=-1 -> garbage WPE backend.
+    auto target = RenderTargetWPEBackend::create(m_surfaceID, m_initialSize, m_hostFD.duplicate(), surface);
     auto window = static_cast<RenderTargetWPEBackend*>(target.get())->window();
     m_lockedTargets.append(WTF::move(target));
     return window;
