#
# Use case for media on Opal for Non EU
#
# LINEOUT1N, 1P, 2N, and 2P are connected to Internal Speaker
# HPOUT1L and 1R are connected to Headphones
# DMICDAT1 is connected internal mic
# IN1LN is connected external mic
# AIF1 is for playback
# AIF2 is for recording

SectionVerb{
	EnableSequence [
	]
	DisableSequence [
	]
	CapturePCM "hw:0,0"
	PlaybackPCM "hw:0,0"
}

SectionDevice."Speaker".0 {
	Comment "For internal speaker and mic"

	EnableSequence [
		cdev "hw:0"
		cset "name='ADC OSR' 0"
		cset "name='AIF2ADCL DRC Switch' on"
		cset "name='AIF2ADC Volume' 114,114"
		cset "name='AIF2ADCL Source' 0"
		cset "name='AIF2ADCR Source' 1"
		cset "name='AIF1DAC1 EQ Switch' on"
		cset "name='AIF1DAC1 Volume' 96,96"
