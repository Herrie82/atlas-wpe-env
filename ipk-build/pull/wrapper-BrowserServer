#!/bin/sh
# WPE 2.52 ATLAS BrowserServer boot wrapper (org.webosports.app.atlas). Exec'd by the `atlas` upstart job.
# Runs the engine IN PLACE from the app's cryptofs deviceroot — NOTHING is copied to /media/internal.
case "$*" in *offscreen*) exit 0 ;; esac
# CONTAINMENT (2026-07-12 hard-lockup): the kernel freezes every crashing process up to
# minicore_timeout seconds (default 60) waiting for /usr/sbin/minicore2 to attach. Our atlas
# LD_LIBRARY_PATH points system busybox tools (pgrep/rm run by the crash path) at the atlas glibc/
# ld-linux, so they SIGSEGV -> each re-enters minicore -> a cascade of 60s freezes piles up and wedges
# the whole device (display MDP starves -> hard lockup requiring a forced reset). Bound the freeze so a
# single crash (or a storm of them) can never take the device down. 5s still lets minicore2 capture
# normal cores; raise it temporarily when you actually need a full BS core for debugging.
[ -w /proc/sys/kernel/minicore_timeout ] && echo 5 > /proc/sys/kernel/minicore_timeout 2>/dev/null
i=0; while [ $i -lt 90 ] && ! ps -ef 2>/dev/null | grep -q '[L]unaSysMgr'; do sleep 1; i=$((i+1)); done
sleep 3
mount -o remount,size=131072k /dev 2>/dev/null
unset LD_PRELOAD
# Derive our own location so the engine root moves with the app (this wrapper lives at $DR/atlas/BrowserServer).
ATLAS=$(cd "$(dirname "$0")" && pwd); DR=$(cd "$ATLAS/.." && pwd); D=$DR/wpe-252
# Camera daemon (getUserMedia bridge, $ATLAS/qcamd). It drives the closed libqcameralib HAL and must
# run under the SYSTEM glibc/glib -- so start it HERE, with the clean upstart env, BEFORE we export
# the atlas LD_LIBRARY_PATH below (loading the atlas glib-2.70 into it hangs the HAL). It only opens
# the camera when a gst client (WebProcess) connects, so it's cheap to leave listening.
if [ -x "$ATLAS/qcamd" ] && ! ps -ef 2>/dev/null | grep -q '[q]camd'; then
    "$ATLAS/qcamd" >/tmp/qcamd.log 2>&1 &
fi
# Speaker daemon (received-audio playback bridge, $ATLAS/qspkd) — the output analog of qcamd/qmicd. The atlas
# WebProcess can't load the device libpulse (SIGSEGV), so the in-browser gst sink atlasqspksink streams PCM to
# /tmp/qspkd.sock and THIS daemon (SYSTEM glibc; dlopen's system libpulse-simple) plays it via PulseAudio ->
# audiod -> speaker. Same reason as qcamd: start it HERE under the clean upstart env, BEFORE the atlas
# LD_LIBRARY_PATH (so it resolves the SYSTEM libpulse, not atlas libs). Cheap: opens pulse only on a connect.
if [ -x "$ATLAS/qspkd" ] && ! ps -ef 2>/dev/null | grep -q '[q]spkd'; then
    "$ATLAS/qspkd" >/tmp/qspkd.log 2>&1 &
fi
cp -f $D/lib/libWPEBackend-atlas.so $D/lib/libWPEBackend-default.so 2>/dev/null
export BPWPE_DEBUG=1
# Do NOT put the atlas $D/lib (glibc-2.52 + ld-linux.so.3) on LD_LIBRARY_PATH: it is INHERITED by the
# kernel crash path (minicore2 replays a crashed atlas proc's env to run busybox pgrep/rm), which then
# SIGSEGV (system ld-linux 2.8 loading atlas libc 2.52) and cascade into a device hard-lockup (2026-07-12).
# All atlas binaries + gst plugins + gio TLS module are rpath-complete (verified: clean-env not-found=0),
# so LD_LIBRARY_PATH is only kept for system paths (harmless to busybox). NOTE: deploy MUST patchelf a
# device rpath onto $D/libexec/gstreamer-1.0/gst-plugin-scanner (its baked rpath points at a host staging
# dir) or the registry scanner subprocess fails to find libgstreamer-1.0 and falls back to in-process.
export LD_LIBRARY_PATH=/usr/lib/ssl11:/usr/lib:/lib
# Microphone daemon (getUserMedia bridge, $ATLAS/qmicd) — the analog of qcamd for audio. Unlike
# qcamd it's an ATLAS glibc-2.52 binary, so it starts HERE, AFTER the atlas LD_LIBRARY_PATH export
# (it needs $D/lib's glib-2.70 + the system liblunaservice/cjson). MUST be started from $ATLAS/qmicd
# (== its LS2 role exeName) or ls-hubd denies LSRegister ("Invalid permissions"). It drives a webOS
# media-server captureV3 recording (the only way to clock the DMIC on the Qualcomm QDSP; hw:0 capture
# is exclusive + silent otherwise) and republishes S16LE PCM to /tmp/qmicd.sock for libgstqmicsrc.so.
if [ -x "$ATLAS/qmicd" ] && ! pgrep qmicd >/dev/null 2>&1; then
    "$ATLAS/qmicd" >/tmp/qmicd.log 2>&1 &
fi
export WPE_BACKEND_LIBRARY=$D/lib/libWPEBackend-atlas.so
export QT_QPA_PLATFORM=Minimal QT_QPA_PLATFORM_PLUGIN_PATH=/usr/plugins/platforms QT_PLUGIN_PATH=/usr/plugins
export FONTCONFIG_FILE=$D/fonts.conf GIO_MODULE_DIR=$D/lib/gio/modules GIO_USE_TLS=openssl SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
export JSC_useDFGJIT=true
export WEBKIT_USE_SINGLE_WEB_PROCESS=1
# --- Phase 1 low-RAM / low-end perf tuning (upstream WPE 2.52, Cairo/Nicosia build) ---
export JSC_forceRAMSize=201326592         # bias JS heaps to a ~192MB budget -> smaller heaps, earlier GC
                                          # (was 256MB; clean reboot-per-config sweep 2026-07-11 showed -49MB on
                                          #  heavy SPAs, ZERO cost on light pages + validated 0% uncovered scroll)
export WEBKIT_EGL_PIXEL_LAYOUT=RGB565      # 16bpp tiles/framebuffer: ~halves GPU/tile memory + bandwidth
export WEBKIT_NICOSIA_PAINTING_THREADS=2   # use BOTH cores for Cairo/Nicosia tile raster. Measured: a
                                           # scroll recenter's render+readback maxStall dropped 674->495ms
                                           # (-27%) — the recenter re-paints the whole 3072px tall buffer and
                                           # that paint was the dominant, single-threaded half. The 2nd core is
                                           # otherwise idle while BS blocks on the GPU readback, so it overlaps
                                           # cleanly (readback ticks up only ~50ms from contention; net win).
export MALLOC_ARENA_MAX=2                  # cap glibc per-thread arenas (GStreamer/fontconfig side)
export BPWPE_NO_STRIP=1                    # DISABLE the P2 scroll-strip readback — correct for the TALL pan
                                           # buffer (default mult=4): on a fling the recenter always jumps
                                           # ~slack/2 (delta ~960-1400px), so the "strip" is ~1/3-1/2 the
                                           # buffer read via the slow sub-rect path + a ~30MB memmove ->
                                           # LOSES to one full-buffer EGL lock_surface readback. A/B (Wikipedia
                                           # fling): strip OFF = 26% uncovered/730ms vs ON = 53%/1432ms. The
                                           # strip only wins for viewport-sized rendering (small deltas).
export BPWPE_SETTLE_VEL=1200               # px/s: a fast flick whose scroll OUTRUNS the buffer above this
                                           # velocity DEFERS to one settle render instead of chaining renders.
                                           # Measured a real flick: the momentum coast runs ~1200-2400 px/s;
                                           # the code default 1500 left the ~1200-1500 coast tail rendering (a
                                           # multi-render grind), so 1200 catches the tail. The inBuffer pan
                                           # check runs BEFORE this gate, so deliberate reading-speed scrolling
                                           # is unaffected — only buffer-outrunning flicks defer. Lower=more
                                           # deferring (blank-then-settle), raise if slow scrolls feel blanky.
ulimit -c unlimited
cd $ATLAS
rm -f /tmp/yapserver.atlas*
export GST_PLUGIN_SYSTEM_PATH=$D/lib/gstreamer-1.0
export GST_OMX_CONFIG_DIR=$D
export GST_PLUGIN_SCANNER=$D/libexec/gstreamer-1.0/gst-plugin-scanner
export GST_REGISTRY=/tmp/atlas-gstreg.bin
export GST_DEBUG=2,webkitregistryscanner:6,omxvideodec:4
# Build the gst plugin registry IN-PROCESS (no forked gst-plugin-scanner). The external scanner helper
# SIGSEGVs when it runs (its baked rpath pointed at a host staging dir; even patched it crashes during
# plugin introspection), which — before the crash-freeze containment — triggered a 5s minicore stall on
# every registry rebuild. In-process build is the path GStreamer already fell back to (registry is
# identical, getUserMedia/webrtc verified), so this just makes it the default and kills the scanner crash.
export GST_REGISTRY_FORK=no
export XDG_DATA_DIRS=$D/share:/usr/share
export GST_OMX_ATLAS_COPY_OUTPUT=1         # reconfigure-safe DPB pmem (copy-mode, no OMX_UseBuffer)
export ATLAS_MDPDETILE=1                   # HW de-tile via MDP rotator
export ATLAS_MDP_NOSWAP=1                  # decoder emits CbCr NV12 already -> no chroma swap in de-tile copy-out
export ATLAS_CAMERA_NO_DECODEBIN=1         # getUserMedia: skip decodebin3 in the capturer (our qcamd feed is raw
                                           # NV12; decodebin3's dynamic pad races the live source -> NOT_LINKED -> black)
# Repoint the baked install-prefix resource dirs at cryptofs: libWPEWebKit's PKGLIBEXECDIR/PKGLIBDIR were
# prefix-patched for the old /media/internal layout, so without these the WebProcess + injected bundle
# would be looked up under /media/internal (which we no longer populate).
export WEBKIT_EXEC_PATH=$D/libexec/wpe-webkit-2.0
export WEBKIT_INJECTED_BUNDLE_PATH=$D/lib/wpe-webkit-2.0/injected-bundle
# Deadlock watchdog: the default 15000ms aborts BS when the main thread stalls in a
# memory-pressure GC / swap-in under heavy accumulated state (idle "random crash" — confirmed
# via core: YapServerDeadlockPriv::deadlockThreadTimerCallback -> abort). A slow GC recovers in
# well under 45s, so raise the timeout so BS survives the stall instead of crash+respawn; a genuine
# deadlock is still caught, just later. Tune via -d / DeadlockTimeoutMs setting (-1 = disabled).
exec $D/BrowserServer-atlas -platform Minimal -d 45000 >/tmp/bs-atlas.log 2>&1
